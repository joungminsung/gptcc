{
  "description": "gptcc: proxy autostart + Auto review hooks",
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/start-proxy.mjs\"",
        "timeout": 10,
        "async": true
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/auto-review.mjs\" record",
        "timeout": 3
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/auto-review.mjs\" stop",
        "timeout": 5
      }
    ]
  }
}
